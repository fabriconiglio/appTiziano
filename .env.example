APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=brevo
MAIL_FROM_ADDRESS="tiendatiziano@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"
BREVO_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

FRONTEND_URL=http://localhost:3000

# Mercado Pago — https://www.mercadopago.com.ar/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# Andreani — https://developers.andreani.com
ANDREANI_USER=
ANDREANI_PASSWORD=
ANDREANI_CLIENTE=
ANDREANI_CONTRATO=
ANDREANI_CP_ORIGEN=5000
ANDREANI_DEBUG=false

# Agenda — Google Calendar (sync de una vía con service account)
GOOGLE_CALENDAR_SYNC=false
GOOGLE_CALENDAR_ID=
# Opcional: ruta al JSON de la service account. Por defecto storage/app/google/service-account.json
# GOOGLE_SERVICE_ACCOUNT_JSON=/ruta/absoluta/al/service-account.json

# Agenda — WhatsApp por Twilio (recordatorios de turnos)
WHATSAPP_ENABLED=false
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_WHATSAPP_FROM=
